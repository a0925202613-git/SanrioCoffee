        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/products/{{product_id}}", "host": ["{{base_url}}"], "path": ["api","v1","products","{{product_id}}"] }
          },
          "response": []
        }
      ]
    },

    {
      "name": "[Consumer] 購物車",
      "description": "需要 consumer token（{{token}}）。加入商品時可附上客製化選項陣列。",
      "item": [
        {
          "name": "Add Item to Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('cart_item_id', String(json.data.id));",
                  "    console.log('cart_item_id saved:', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/cart/items", "host": ["{{base_url}}"], "path": ["api","v1","cart","items"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": {{product_id}},\n  \"quantity\": 2,\n  \"customizations\": [\n    { \"option_type\": \"size\",  \"name\": \"大杯\",  \"price_delta\": 20 },\n    { \"option_type\": \"ice\",   \"name\": \"少冰\",  \"price_delta\": 0  },\n    { \"option_type\": \"sugar\", \"name\": \"半糖\",  \"price_delta\": 0  },\n    { \"option_type\": \"addon\", \"name\": \"燕麥奶\",\"price_delta\": 30 }\n  ]\n}"
            }
          },
          "response": []
        },
        {
          "name": "Add Item (無客製化)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/cart/items", "host": ["{{base_url}}"], "path": ["api","v1","cart","items"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": {{product_id}},\n  \"quantity\": 1,\n  \"customizations\": []\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/cart", "host": ["{{base_url}}"], "path": ["api","v1","cart"] }
          },
          "response": []
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/cart/items/{{cart_item_id}}", "host": ["{{base_url}}"], "path": ["api","v1","cart","items","{{cart_item_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3,\n  \"customizations\": [\n    { \"option_type\": \"size\", \"name\": \"大杯\", \"price_delta\": 20 }\n  ]\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Cart Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/cart/items/{{cart_item_id}}", "host": ["{{base_url}}"], "path": ["api","v1","cart","items","{{cart_item_id}}"] }
          },
          "response": []
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/cart", "host": ["{{base_url}}"], "path": ["api","v1","cart"] }
          },
          "response": []
        }
      ]
    },

    {
      "name": "[Consumer] 點餐下單",
      "description": "建立訂單會在單一事務中：鎖優惠券 → 扣點數 → 建訂單 → 建明細 → 入點數 → 清購物車。",
      "item": [
        {
          "name": "Validate Coupon（預覽折扣，不扣次數）",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/coupons/validate", "host": ["{{base_url}}"], "path": ["api","v1","coupons","validate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{coupon_code}}\",\n  \"order_amount\": 500\n}"
            }
          },
          "response": []
        },
        {
          "name": "Create Order（無優惠）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('order_id', String(json.data.id));",
                  "    console.log('order_id saved:', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/orders", "host": ["{{base_url}}"], "path": ["api","v1","orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"請幫我多附一根吸管，謝謝～\",\n  \"pickup_time\": null\n}"
            }
          },
          "response": []
        },
        {
