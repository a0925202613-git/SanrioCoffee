    {
      "name": "[Admin] 優惠券管理",
      "description": "需要 admin_token。支援固定金額（fixed）與百分比（percentage）兩種折扣類型。",
      "item": [
        {
          "name": "Create Coupon: 固定金額 (fixed)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var now = new Date();",
                  "var until = new Date(now.getTime() + 30 * 24 * 60 * 60 * 1000);",
                  "pm.variables.set('valid_from', now.toISOString());",
                  "pm.variables.set('valid_until', until.toISOString());"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('coupon_id', String(json.data.id));",
                  "    pm.collectionVariables.set('coupon_code', json.data.code);",
                  "    console.log('coupon_id saved:', json.data.id, '| code:', json.data.code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
