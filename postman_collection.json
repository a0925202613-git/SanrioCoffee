            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"WELCOME10\",\n  \"name\": \"新會員優惠 折抵 NT$50\",\n  \"discount_type\": \"fixed\",\n  \"discount_value\": 50,\n  \"min_order_amount\": 200,\n  \"valid_from\": \"{{valid_from}}\",\n  \"valid_until\": \"{{valid_until}}\",\n  \"usage_limit\": 100\n}"
            }
