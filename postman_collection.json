    {
      "name": "[付款] 假金流",
      "description": "Initiate 建立付款記錄並產生假 transaction_id。Callback 模擬金流回調（90% 隨機成功；force_result 可指定結果）。",
      "item": [
        {
          "name": "Initiate Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.transaction_id) {",
                  "    pm.collectionVariables.set('transaction_id', json.data.transaction_id);",
                  "    console.log('transaction_id saved:', json.data.transaction_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/payments/initiate", "host": ["{{base_url}}"], "path": ["api","v1","payments","initiate"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_id\": {{order_id}},\n  \"method\": \"credit_card\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Callback: Force Success",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/payments/callback", "host": ["{{base_url}}"], "path": ["api","v1","payments","callback"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transaction_id\": \"{{transaction_id}}\",\n  \"force_result\": \"success\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Callback: Force Failed",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/payments/callback", "host": ["{{base_url}}"], "path": ["api","v1","payments","callback"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transaction_id\": \"{{transaction_id}}\",\n  \"force_result\": \"failed\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Callback: Random (90% 成功)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/v1/payments/callback", "host": ["{{base_url}}"], "path": ["api","v1","payments","callback"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transaction_id\": \"{{transaction_id}}\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Callback: via Query Param (GET 模擬 webhook)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/payments/callback?transaction_id={{transaction_id}}&force_result=success",
              "host": ["{{base_url}}"],
              "path": ["api","v1","payments","callback"],
              "query": [
                { "key": "transaction_id", "value": "{{transaction_id}}" },
                { "key": "force_result",   "value": "success" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Payment Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/payments/{{order_id}}/status", "host": ["{{base_url}}"], "path": ["api","v1","payments","{{order_id}}","status"] }
          },
          "response": []
        }
      ]
    },

