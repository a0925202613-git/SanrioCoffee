        },
        {
          "name": "Upload Product Image (form-data)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/products/upload", "host": ["{{base_url}}"], "path": ["api","v1","products","upload"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "image", "type": "file", "src": "", "description": "選擇 jpg/png/webp 圖片，上限 5MB" }
              ]
            }
          },
          "response": []
