            "url": { "raw": "{{base_url}}/api/v1/products/{{product_id}}/availability", "host": ["{{base_url}}"], "path": ["api","v1","products","{{product_id}}","availability"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_available\": false\n}"
            }
          },
          "response": []
        },
        {
          "name": "Set Availability: 上架",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/products/{{product_id}}/availability", "host": ["{{base_url}}"], "path": ["api","v1","products","{{product_id}}","availability"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_available\": true\n}"
            }
          },
          "response": []
        },
        {
          "name": "Add Customization: 杯型 (size)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "    pm.collectionVariables.set('option_id', String(json.data.id));",
                  "    console.log('option_id saved:', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/products/{{product_id}}/customizations", "host": ["{{base_url}}"], "path": ["api","v1","products","{{product_id}}","customizations"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"option_type\": \"size\",\n  \"name\": \"大杯\",\n  \"price_delta\": 20,\n  \"sort_order\": 1\n}"
            }
          },
          "response": []
        },
        {
          "name": "Add Customization: 冰量 (ice)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/products/{{product_id}}/customizations", "host": ["{{base_url}}"], "path": ["api","v1","products","{{product_id}}","customizations"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"option_type\": \"ice\",\n  \"name\": \"少冰\",\n  \"price_delta\": 0,\n  \"sort_order\": 1\n}"
            }
          },
          "response": []
        },
        {
          "name": "Add Customization: 甜度 (sugar)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/products/{{product_id}}/customizations", "host": ["{{base_url}}"], "path": ["api","v1","products","{{product_id}}","customizations"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"option_type\": \"sugar\",\n  \"name\": \"半糖\",\n  \"price_delta\": 0,\n  \"sort_order\": 1\n}"
            }
          },
          "response": []
        },
        {
          "name": "Add Customization: 加料 (addon)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/products/{{product_id}}/customizations", "host": ["{{base_url}}"], "path": ["api","v1","products","{{product_id}}","customizations"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"option_type\": \"addon\",\n  \"name\": \"燕麥奶\",\n  \"price_delta\": 30,\n  \"sort_order\": 1\n}"
            }
          },
          "response": []
